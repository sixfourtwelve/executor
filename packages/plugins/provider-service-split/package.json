{
  "name": "@executor-js/plugin-provider-service-split",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./planner": "./src/planner.ts",
    "./sqlite": "./src/sqlite.ts"
  },
  "scripts": {
    "build": "tsup && (tsc --declaration --emitDeclarationOnly --outDir dist --rootDir src || true)",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:slow": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@executor-js/plugin-openapi": "workspace:*",
    "@executor-js/sdk": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "bun-types": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
